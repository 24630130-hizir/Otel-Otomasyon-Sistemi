<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kingo Luxury Resort</title>

    <link rel="icon" type="image/png" href="https://cdn-icons-png.flaticon.com/512/2696/2696144.png">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --gold: #d4af37;
            --gold-bright: #f1d37e;
            --dark: #030712;
            --glass: rgba(255, 255, 255, 0.03);
            --border: rgba(255, 255, 255, 0.1);
        }

        body {
            background-color: var(--dark);
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow-x: hidden;
        }

        .brand-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            transition: transform 0.3s ease;
        }

            .brand-wrapper:hover {
                transform: scale(1.02);
            }

        .logo-icon {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            border: 1px solid var(--gold);
            border-radius: 12px;
            background: linear-gradient(45deg, rgba(212, 175, 55, 0.1), transparent);
        }

            .logo-icon i {
                font-size: 1.5rem;
                color: var(--gold);
            }

        .logo-text {
            display: flex;
            flex-direction: column;
            line-height: 1;
        }

        .logo-main {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 2px;
            margin-bottom: 2px;
        }

        .logo-sub {
            font-size: 0.6rem;
            letter-spacing: 3px;
            color: var(--gold);
            text-transform: uppercase;
        }

   
        .navbar {
            background: rgba(3, 7, 18, 0.85) !important;
            backdrop-filter: blur(25px);
            border-bottom: 1px solid var(--border);
            padding: 15px 0;
            transition: all 0.4s ease;
        }

            .navbar.scrolled {
                padding: 8px 0;
                background: rgba(3, 7, 18, 0.98) !important;
            }

        .nav-link {
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-weight: 600;
            color: rgba(255,255,255,0.7) !important;
            margin-left: 25px;
            position: relative;
            padding: 5px 0;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                width: 0;
                height: 1px;
                background: var(--gold);
                transition: width 0.3s ease;
            }

            .nav-link:hover {
                color: var(--gold) !important;
            }

                .nav-link:hover::after {
                    width: 100%;
                }

        .lang-nav {
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            color: #fff;
            border-radius: 8px;
            font-size: 0.75rem;
            padding: 6px 12px;
            margin-left: 25px;
            cursor: pointer;
            outline: none;
            transition: 0.3s;
        }

            .lang-nav:hover {
                border-color: var(--gold);
                background: rgba(212, 175, 55, 0.1);
            }
            
            .lang-nav option {
                background-color: #111; 
                color: #fff; 
                padding: 10px;
            }

        .btn-outline-gold {
            border: 1px solid var(--gold);
            color: var(--gold);
            background: transparent;
            transition: 0.3s;
            font-weight: 700;
            font-size: 0.75rem;
            letter-spacing: 1px;
            border-radius: 50px;
            padding: 8px 25px;
        }

            .btn-outline-gold:hover {
                background: var(--gold);
                color: #000;
            }

        .btn-solid-gold {
            background: var(--gold);
            color: #000;
            border: none;
            font-weight: 800;
            font-size: 0.75rem;
            letter-spacing: 1px;
            border-radius: 50px;
            padding: 8px 25px;
            transition: 0.3s;
        }

            .btn-solid-gold:hover {
                background: #fff;
                transform: translateY(-2px);
            }

        footer {
            background: #000;
            padding: 80px 0 40px;
            border-top: 1px solid var(--border);
            margin-top: 100px;
        }

        .gold-gradient-text {
            background: linear-gradient(135deg, #fff 0%, var(--gold) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .main-wrapper {
            animation: fadeInPage 1.2s ease-out;
        }

        .btn-outline-gold {
            border: 1px solid var(--gold);
            color: var(--gold);
            background: transparent;
            transition: 0.3s;
            font-weight: 600;
            font-size: 0.75rem;
            letter-spacing: 1px;
            border-radius: 8px;
        }

            .btn-outline-gold:hover {
                background: var(--gold);
                color: #000;
            }

        .auth-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(15px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
        }

        .auth-card {
            background: #0f172a;
            border: 1px solid var(--gold);
            border-radius: 24px;
            width: 100%;
            max-width: 400px;
            padding: 40px;
            position: relative;
            box-shadow: 0 0 50px rgba(212, 175, 55, 0.15);
        }

        .auth-tabs {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .auth-tab {
            padding: 10px 0;
            color: #64748b;
            cursor: pointer;
            font-weight: 700;
            font-size: 0.9rem;
            position: relative;
        }

            .auth-tab.active {
                color: var(--gold);
            }

                .auth-tab.active::after {
                    content: '';
                    position: absolute;
                    bottom: -1px;
                    left: 0;
                    width: 100%;
                    height: 2px;
                    background: var(--gold);
                }

        .form-input-group {
            position: relative;
            margin-bottom: 20px;
        }

            .form-input-group i {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--gold);
            }

            .form-input-group input {
                width: 100%;
                background: rgba(255,255,255,0.03);
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 12px;
                padding: 12px 15px 12px 45px;
                color: #fff;
                outline: none;
                transition: 0.3s;
            }

                .form-input-group input:focus {
                    border-color: var(--gold);
                    background: rgba(255,255,255,0.05);
                }

        .btn-auth {
            background: var(--gold);
            color: #000;
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 12px;
            font-weight: 800;
            margin-top: 10px;
            transition: 0.3s;
        }

            .btn-auth:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(212,175,55,0.3);
            }

        #ai-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 65px;
            height: 65px;
            background: linear-gradient(135deg, var(--gold), #aa8928);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-size: 1.8rem;
            cursor: pointer;
            z-index: 9998;
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.3);
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

            #ai-btn:hover {
                transform: scale(1.1) rotate(15deg);
            }

        #ai-panel {
            position: fixed;
            bottom: 110px;
            right: 30px;
            width: 380px;
            height: 550px;
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid var(--gold);
            border-radius: 24px;
            display: none;
            flex-direction: column;
            z-index: 9999;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        .ai-header {
            background: linear-gradient(to right, rgba(212, 175, 55, 0.1), transparent);
            padding: 20px;
            border-bottom: 1px solid rgba(212,175,55,0.2);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .ai-body {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .ai-msg {
            max-width: 85%;
            padding: 12px 16px;
            border-radius: 18px;
            font-size: 0.9rem;
            line-height: 1.4;
        }

            .ai-msg.bot {
                background: rgba(255,255,255,0.05);
                color: #fff;
                align-self: flex-start;
                border-bottom-left-radius: 4px;
            }

            .ai-msg.user {
                background: var(--gold);
                color: #000;
                align-self: flex-end;
                border-bottom-right-radius: 4px;
                font-weight: 600;
            }

        .ai-footer {
            padding: 20px;
            border-top: 1px solid rgba(255,255,255,0.05);
            background: rgba(0,0,0,0.2);
        }

        .ai-input-wrapper {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 15px;
            display: flex;
            padding: 5px 15px;
            align-items: center;
        }

            .ai-input-wrapper input {
                flex: 1;
                background: transparent;
                border: none;
                color: #fff;
                padding: 10px 0;
                outline: none;
                font-size: 0.9rem;
            }

        @@keyframes fadeInPage {
            0% {
                opacity: 0;
                transform: translateY(15px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 991px) {
            .nav-link { margin-left: 0; padding: 10px 0; font-size: 0.85rem; }
            .lang-nav { margin-left: 0; margin-top: 8px; width: 100%; }
            #auth-buttons { flex-direction: row; gap: 8px; margin-top: 10px; }
            #auth-buttons .btn { flex: 1; text-align: center; font-size: 0.75rem; padding: 8px 10px; }
            .navbar-collapse { padding: 10px 0; }
     
            .nav-item.ms-lg-2 { margin-top: 8px; }
            .nav-item.ms-lg-2 button { width: 100%; justify-content: center; margin-left: 0 !important; }
        }

        @@media (max-width: 767px) {
            .logo-main { font-size: 1.2rem; }
            .logo-sub { font-size: 0.55rem; }
            .logo-icon { width: 38px; height: 38px; }
            footer { padding: 40px 0 20px; margin-top: 50px; }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <div class="brand-wrapper">
                    <div class="logo-icon">
                        <i class="bi bi-building-fill"></i>
                        <i class="bi bi-crown-fill" style="position:absolute; top:-10px; font-size:0.8rem;"></i>
                    </div>
                    <div class="logo-text">
                        <span class="logo-main gold-gradient-text">KINGO</span>
                        <span class="logo-sub">Luxury Resort</span>
                    </div>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#kingoNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="kingoNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link" id="nav-home" asp-controller="Home" asp-action="Index">ANA SAYFA</a></li>
                    <li class="nav-item"><a class="nav-link" id="nav-rooms" asp-controller="Home" asp-action="OtelleriListele">ODALAR</a></li>
                    <li class="nav-item"><a class="nav-link" id="nav-about" asp-controller="Home" asp-action="Hakkimizda">HAKKIMIZDA</a></li>
                    <li class="nav-item"><a class="nav-link" id="nav-contact" asp-controller="Home" asp-action="Iletisim">İLETİŞİM</a></li>
                    <li class="nav-item"><a class="nav-link" id="nav-report" href="javascript:void(0)" onclick="reportProblem()" style="color:var(--gold) !important">SORUN BİLDİR</a></li>
                    <li class="nav-item"><a class="nav-link" id="nav-admin" href="/Admin" style="color:rgba(212,175,55,0.7) !important; font-size:0.7rem; letter-spacing:1.5px;"><i class="bi bi-shield-lock me-1"></i>ADMİN</a></li>

                    <li class="nav-item ms-lg-3 d-flex gap-2" id="auth-buttons">
                        <a class="btn btn-outline-gold" id="btn-login" asp-controller="Account" asp-action="Login">GİRİŞ YAP</a>
                        <a class="btn btn-solid-gold" id="btn-register" asp-controller="Account" asp-action="Register">ÜYE OL</a>
                    </li>

                    <li class="nav-item d-none" id="user-profile">
                        <div class="dropdown ms-lg-3">
                            <button class="btn btn-outline-gold px-4 rounded-pill d-flex align-items-center gap-2 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5"></i>
                                <span id="user-name-display" class="fw-700 text-uppercase" style="letter-spacing: 1px;">Misafir</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end bg-dark border-gold border-opacity-25 mt-2 animate__animated animate__fadeIn">
                                <li><a class="dropdown-item py-2" href="javascript:void(0)" onclick="showMyRez()"><i class="bi bi-calendar-check me-2"></i>Rezervasyonlarım</a></li>
                                <li><hr class="dropdown-divider border-white border-opacity-10"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="javascript:void(0)" onclick="logoutUsers()"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</a></li>
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item">
                        <select class="lang-nav" id="globalLangSelector" onchange="globalChangeLang(this.value)">
                            <option value="tr">TR</option>
                            <option value="en">EN</option>
                            <option value="de">DE</option>
                            <option value="fr">FR</option>
                            <option value="ru">RU</option>
                            <option value="es">ES</option>
                        </select>
                    </li>
                    <li class="nav-item ms-lg-2">
                        <a href="/Admin/Download" class="btn btn-outline-gold d-flex align-items-center justify-content-center gap-2" style="padding: 6px 12px; margin-left: 25px; border-radius: 8px;">
                            <i class="bi bi-download"></i> PANELİ İNDİR
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="main-wrapper">
        @RenderBody()
    </div>

    </footer>

    @* Auth modals replaced by dedicated Account pages *@

    <!-- AI ASSISTANT -->
    <div id="ai-btn" onclick="toggleAI()">
        <i class="bi bi-robot"></i>
    </div>

    <div id="ai-panel" class="animate__animated">
        <div class="ai-header">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle bg-gold p-2 d-flex align-items-center justify-content-center" style="width:40px; height:40px; background:var(--gold); color:#000;">
                    <i class="bi bi-robot fs-5"></i>
                </div>
                <div>
                    <h6 class="m-0 fw-bold">Kingo Asistan</h6>
                    <small class="text-success" style="font-size: 0.7rem;"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i> Çevrimiçi</small>
                </div>
            </div>
            <button class="btn-close btn-close-white" onclick="toggleAI()"></button>
        </div>
        <div class="ai-body" id="ai-chat-body">
            <div class="ai-msg bot">
                Merhaba! Ben Kingo Luxury Resort asistanıyım. Size rezervasyon, odalarımız veya otelimizle ilgili nasıl yardımcı olabilirim?
            </div>
        </div>
        <div id="ai-chips" class="px-3 py-3 d-flex flex-column gap-2 bg-black bg-opacity-25" style="border-top: 1px solid rgba(255,255,255,0.05); max-height: 250px; overflow-y: auto;">
            <button class="btn btn-outline-gold btn-sm py-2 px-3 rounded-pill text-start w-100" style="font-size: 0.8rem; border-width: 1px;" onclick="sendQuickMsg('İptal Koşulları?')">İptal Koşulları?</button>
            <button class="btn btn-outline-gold btn-sm py-2 px-3 rounded-pill text-start w-100" style="font-size: 0.8rem; border-width: 1px;" onclick="sendQuickMsg('Ödeme Yöntemleri?')">Ödeme Yöntemleri?</button>
            <button class="btn btn-outline-gold btn-sm py-2 px-3 rounded-pill text-start w-100" style="font-size: 0.8rem; border-width: 1px;" onclick="sendQuickMsg('Kahvaltı Saati?')">Kahvaltı Saati?</button>
            <button class="btn btn-outline-gold btn-sm py-2 px-3 rounded-pill text-start w-100" style="font-size: 0.8rem; border-width: 1px;" onclick="sendQuickMsg('Havuz & SPA?')">Havuz & SPA Giriş?</button>
            <button class="btn btn-outline-gold btn-sm py-2 px-3 rounded-pill text-start w-100" style="font-size: 0.8rem; border-width: 1px;" onclick="sendQuickMsg('Check-in / Out?')">Check-in / Check-out Saatleri?</button>
            <button class="btn btn-outline-gold btn-sm py-2 px-3 rounded-pill text-start w-100" style="font-size: 0.8rem; border-width: 1px;" onclick="sendQuickMsg('Otopark?')">Otopark ve Vale Hizmeti?</button>
            <button class="btn btn-outline-gold btn-sm py-2 px-3 rounded-pill text-start w-100" style="font-size: 0.8rem; border-width: 1px;" onclick="sendQuickMsg('Wi-Fi?')">İnternet / Wi-Fi Erişimi?</button>
            <button class="btn btn-outline-gold btn-sm py-2 px-3 rounded-pill text-start w-100" style="font-size: 0.8rem; border-width: 1px;" onclick="sendQuickMsg('Evcil Hayvan?')">Evcil Hayvan Kabulü?</button>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    
    <div class="modal fade" id="myRezModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content" style="background:#0f172a;border:1px solid rgba(212,175,55,0.35);border-radius:20px;">
                <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.08);padding:20px 28px;">
                    <h5 class="modal-title fw-800" style="color:#d4af37;letter-spacing:1px;"><i class="bi bi-list-check me-2"></i>REZERVASYONLARIM</h5>
                    <div class="d-flex align-items-center gap-2">
                        <button onclick="loadMyRez()" style="background:rgba(212,175,55,0.12);border:1px solid rgba(212,175,55,0.4);color:#d4af37;padding:5px 12px;border-radius:10px;font-size:0.75rem;font-weight:700;cursor:pointer;"><i class="bi bi-arrow-clockwise me-1"></i>Yenile</button>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                </div>
                <div class="modal-body" style="padding:24px 28px;" id="myRezBody">
                    <p class="text-white-50 text-center py-4"><i class="bi bi-hourglass-split me-2"></i>Yükleniyor...</p>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.addEventListener('scroll', function() {
            const nav = document.getElementById('mainNav');
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });

        const translations = window.translations = {
            tr: { 
