                heroTitle: "KINGO LUXURY", heroSub: "RESERVATION PANEL",
                labelCity: "CITY & HOTEL", labelIn: "CHECK-IN", labelOut: "CHECK-OUT", labelSelected: "SELECTED ROOM:",
