                phAd: "Your Name", phSoyad: "Your Surname", phTc: "ID Number (Optional)", phTel: "Phone", phMail: "E-mail",
                btnComplete: "COMPLETE RESERVATION",
                rezTitle: "Reservation Details",
                floor: "FLOOR", bedsFull: "Beds Occupied", perNight: "/ Night", noRooms: "No rooms found on this floor."
            },
            de: {
                home: "Startseite", rooms: "Zimmer", about: "Über Uns", contact: "Kontakt", copy: "Alle Rechte vorbehalten.",
                report: "Problem melden", login: "Anmelden", register: "Registrieren", myrez: "Meine Reservierungen",
                heroTitle: "KINGO LUXURY", heroSub: "RESERVIERUNGSPANEL",
