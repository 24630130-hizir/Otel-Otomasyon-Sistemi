        window.globalChangeLang = function(lang) {
            localStorage.setItem("selectedLang", lang);
            const d = translations[lang] || translations['en'];
            if (d) {
                $("#nav-home").text(d.home.toUpperCase());
                $("#nav-rooms").text(d.rooms.toUpperCase());
                $("#nav-about").text(d.about.toUpperCase());
                $("#nav-contact").text(d.contact.toUpperCase());
                $("#nav-report").text(d.report.toUpperCase());
                $("#nav-reservations-link").text(d.myrez.toUpperCase());
                $("#btn-login").text(d.login.toUpperCase());
                $("#btn-register").text(d.register.toUpperCase());
                
                $(".brand-title").text(d.heroTitle);
                $(".hero-subtitle").text(d.heroSub);
                $(".label-city").text(d.labelCity);
                $(".label-in").text(d.labelIn);
                $(".label-out").text(d.labelOut);
                $(".label-selected").text(d.labelSelected);
                $(".label-rez-title").text(d.rezTitle);
                
                $("#info-l-hava").text(d.infoHava);
                $("#info-l-deniz").text(d.infoDeniz);
                $("#info-l-konum").text(d.infoKonum);
                
                $("#Ad").attr("placeholder", d.phAd);
                $("#Soyad").attr("placeholder", d.phSoyad);
                $("#TcNo").attr("placeholder", d.phTc);
                $("#Telefon").attr("placeholder", d.phTel);
                $("#Email").attr("placeholder", d.phMail);
                $("#btn-final-reserve").text(d.btnComplete.toUpperCase());

                $("#footer-copy").html(`&copy; 2026 Kingo Resort & Spa. ${d.copy}`);

                const _kat = $("#otelSelect").find(':selected').data('kat');
                if (_kat && typeof renderFloorNav === 'function') renderFloorNav(_kat);
                if (window.allRooms && typeof renderRooms === 'function') {
                    const _floor = parseInt($('.floor-btn.active').attr('data-floor')) || 1;
                    renderRooms(_floor);
                }
            }

            if (typeof setLanguage === 'function') {
                setLanguage(lang);
            }
        }

        function reportProblem() {
            Swal.fire({
                title: '<span style="color:var(--gold)">SORUN BİLDİR</span>',
                html: `
                    <div class="text-start px-3">
                        <label class="small text-white-50 mb-1">Sorun Kategorisi</label>
                        <select id="swal-cate" class="form-select bg-dark text-white border-white border-opacity-25 mb-3">
                            <option>Ödeme Sorunları</option>
                            <option>Rezervasyon Hatası</option>
                            <option>Sistem/Arayüz Hatası</option>
                            <option>Diğer</option>
                        </select>
                        <label class="small text-white-50 mb-1">Açıklamanız</label>
                        <textarea id="swal-desc" class="form-control bg-dark text-white border-white border-opacity-25" style="height:100px" placeholder="Sorunu detaylandırın..."></textarea>
                    </div>
                `,
                background: '#0f172a',
                showCancelButton: true,
                confirmButtonText: 'GÖNDER',
                cancelButtonText: 'İPTAL',
                confirmButtonColor: '#d4af37',
                cancelButtonColor: '#334155',
                preConfirm: () => {
                    const desc = Swal.getPopup().querySelector('#swal-desc').value;
                    if (!desc) { Swal.showValidationMessage('Lütfen bir açıklama girin'); return false; }
                    const cate = Swal.getPopup().querySelector('#swal-cate').value;
                    return { desc, cate };
                }
            }).then((result) => {
                if (!result.isConfirmed) return;
                const user = JSON.parse(localStorage.getItem('user') || '{}');
                $.post('/Admin/SorunBildir', {
                    kategori: result.value.cate,
                    aciklama: result.value.desc,
                    kullaniciAd: user.username || user.name || 'Misafir'
                }, function(res) {
                    Swal.fire({
                        title: res.success ? 'Gönderildi!' : 'Hata',
                        text: res.success ? 'Sorununuz yöneticilere iletildi. Teşekkürler.' : (res.message || 'Bir hata oluştu.'),
                        icon: res.success ? 'success' : 'error',
                        confirmButtonColor: '#d4af37',
                        background: '#0f172a', color: '#fff'
                    });
                }).fail(() => {
                    Swal.fire({ title: 'Hata', text: 'Gönderilemedi.', icon: 'error', confirmButtonColor: '#d4af37', background: '#0f172a', color: '#fff' });
                });
            });
        }

        function promptAdminDownload() {
            Swal.fire({
                title: '<span style="color:var(--gold)">Yönetici Doğrulaması</span>',
                html: `
                    <div class="text-start px-3">
                        <label class="small text-white-50 mb-1">Kullanıcı Adı</label>
                        <input id="swal-admin-user" class="form-control bg-dark text-white border-white border-opacity-25 mb-3" type="text" placeholder="Kullanıcı adı...">
                        <label class="small text-white-50 mb-1">Şifre</label>
                        <input id="swal-admin-pass" class="form-control bg-dark text-white border-white border-opacity-25" type="password" placeholder="Şifre...">
                    </div>
                `,
                background: '#0f172a',
                showCancelButton: true,
                confirmButtonText: 'DOĞRULA VE İNDİR',
                cancelButtonText: 'İPTAL',
                confirmButtonColor: '#d4af37',
                cancelButtonColor: '#334155',
                preConfirm: () => {
                    const user = Swal.getPopup().querySelector('#swal-admin-user').value;
                    const pass = Swal.getPopup().querySelector('#swal-admin-pass').value;
                    if (!user || !pass) {
                        Swal.showValidationMessage('Lütfen kullanıcı adı ve şifreyi giriniz.');
                        return false;
                    }
                    if (user !== "administrator" || pass !== "admin") {
                        Swal.showValidationMessage('Kullanıcı adı veya şifre hatalı!');
                        return false;
                    }
                    return true;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Erişim Onaylandı!',
                        text: 'Kurulum dosyası indiriliyor...',
                        icon: 'success',
                        confirmButtonColor: '#d4af37',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    setTimeout(() => {
                        window.location.href = '/downloads/OtelYonetimPaneli_Setup.zip';
                    }, 1000);
                }
            });
        }

        function openAuthModal(type) {
            $("#authOverlay").css("display", "flex");
            switchAuthTab(type);
        }

        function closeAuthModal() {
            $("#authOverlay").hide();
        }

        function switchAuthTab(type) {
            $(".auth-tab").removeClass("active");
            $(`#tab-${type}`).addClass("active");
            if (type === 'login') {
                $("#login-form").show(); $("#register-form").hide();
            } else {
                $("#login-form").hide(); $("#register-form").show();
            }
        }

        function checkUserStatus() {
            const userData = localStorage.getItem("user");
            if (userData) {
                try {
                    const user = JSON.parse(userData);
                    // Geçersiz veri varsa temizle
                    if (!user || !user.username) {
                        localStorage.removeItem("user");
                        $("#auth-buttons").removeClass("d-none");
                        $("#user-profile").addClass("d-none");
                        return;
                    }
                    $("#auth-buttons").addClass("d-none");
                    $("#user-profile").removeClass("d-none");
                    $("#user-name-display").text(user.name || user.username);
                } catch(e) {
                    localStorage.removeItem("user");
                    $("#auth-buttons").removeClass("d-none");
                    $("#user-profile").addClass("d-none");
                }
            } else {
                $("#auth-buttons").removeClass("d-none");
                $("#user-profile").addClass("d-none");
            }
        }

        function logoutUsers() {
            localStorage.removeItem("user");
            checkUserStatus();
            location.href = '/';
        }

        let aiOpen = false;
        function toggleAI() {
            aiOpen = !aiOpen;
            const panel = $("#ai-panel");
            if(aiOpen) {
                panel.css("display", "flex").removeClass("animate__fadeOutDown").addClass("animate__fadeInUp");
            } else {
                panel.removeClass("animate__fadeInUp").addClass("animate__fadeOutDown");
                setTimeout(() => { if(!aiOpen) panel.hide(); }, 500);
            }
        }

        function sendQuickMsg(val) {
            processAIMsg(val);
        }

        function processAIMsg(val) {
            $("#ai-chat-body").append(`<div class="ai-msg user">${val}</div>`);
            $("#ai-chat-body").scrollTop($("#ai-chat-body")[0].scrollHeight);

            setTimeout(() => {
                let reply = "Size bu konuda yardımcı olmak için detayları inceliyorum. Lütfen bekleyin...";
                const v = val.toLowerCase();
                if(v.includes("iptal")) reply = "Rezervasyonlarınızı 24 saat öncesine kadar %20 komisyon kesintisi ile iptal edebilir veya ücretsiz olarak açığa alabilirsiniz.";
                else if(v.includes("ödeme")) reply = "Güvenli 256-bit SSL sertifikalı altyapımız üzerinden tüm kredi kartları ile ödeme yapabilirsiniz.";
                else if(v.includes("olanak")) reply = "Otellerimizde özel SPA, panoramik manzaralı balkonlar, 7/24 oda servisi ve alakart restoranlar bulunmaktadır.";
                else if(v.includes("oda")) reply = "Lüks odalarımız, panoramik deniz manzarasına sahip balkonları ve özel SPA olanaklarıyla donatılmıştır.";
                else if(v.includes("rezervasyon")) reply = "Rezervasyon paneli üzerinden dilediğiniz tarih aralığını seçerek hızlıca işlem yapabilirsiniz.";
                else if(v.includes("kahvaltı")) reply = "Kahvaltı servisimiz her sabah 07:00 - 11:00 saatleri arasında ana restoranda açık büfe olarak sunulmaktadır.";
                else if(v.includes("havuz") || v.includes("spa")) reply = "Havuz ve SPA merkezimiz sabah 08:00'den akşam 22:00'ye kadar tüm misafirlerimizin kullanımına açıktır.";
                else if(v.includes("check-in") || v.includes("giriş saati")) reply = "Standart giriş (Check-in) saati 14:00, çıkış (Check-out) saati ise 12:00'dir. Erken giriş için müsaitlik kontrolü yapılabilir.";
                else if(v.includes("otopark") || v.includes("vale")) reply = "Tesisimizde konaklayan misafirlerimiz için ücretsiz kapalı otopark ve vale hizmetimiz bulunmaktadır.";
                else if(v.includes("wi-fi") || v.includes("internet")) reply = "Tüm odalarımızda ve genel alanlarda yüksek hızlı Wi-Fi erişimi tamamen ücretsizdir.";
                else if(v.includes("evcil")) reply = "Belirli odalarımızda küçük dostlarımızı (evcil hayvan) kabul edebiliyoruz. Lütfen rezervasyon öncesi bilgi alınız.";
                else if(v.includes("transfer")) reply = "Havalimanı transfer talepleriniz için misafir ilişkileri departmanımızla 24 saat önceden iletişime geçebilirsiniz.";

                $("#ai-chat-body").append(`<div class="ai-msg bot">${reply}</div>`);
                $("#ai-chat-body").scrollTop($("#ai-chat-body")[0].scrollHeight);
            }, 800);
        }

        function durumBadge(durum) {
            const map = {
                'Aktif':        { bg: '#10b981', icon: 'bi-check-circle-fill' },
                'OdaKapatildi': { bg: '#f59e0b', icon: 'bi-lock-fill' },
                'İptal Edildi': { bg: '#ef4444', icon: 'bi-x-circle-fill' },
                'Açığa Alındı': { bg: '#6366f1', icon: 'bi-pause-circle-fill' },
                'Kullanıldı':   { bg: '#64748b', icon: 'bi-archive-fill' }
            };
            const s = map[durum] || { bg: '#94a3b8', icon: 'bi-question-circle-fill' };
            return `<span style="background:${s.bg};color:#fff;padding:3px 10px;border-radius:20px;font-size:0.7rem;font-weight:700;white-space:nowrap;"><i class="bi ${s.icon} me-1"></i>${durum}</span>`;
        }

        function showMyRez() {
            const user = JSON.parse(localStorage.getItem('user'));
            if (!user) { location.href = '/Account/Login'; return; }
            const modal = new bootstrap.Modal(document.getElementById('myRezModal'));
            modal.show();
            loadMyRez();
        }

        function loadMyRez() {
            const user = JSON.parse(localStorage.getItem('user'));
            if (!user) return;
            $('#myRezBody').html('<p class="text-white-50 text-center py-4"><i class="bi bi-hourglass-split me-2"></i>Yükleniyor...</p>');
            $.get('/Rezervasyon/GetMyReservations', { email: user.email || '', username: user.username || '' }, function(data) {
                if (!data || data.length === 0) {
                    $('#myRezBody').html('<p class="text-white-50 text-center py-5"><i class="bi bi-inbox fs-2 d-block mb-2"></i>Henüz rezervasyonunuz bulunmamaktadır.</p>');
                    return;
                }
                let h = '<div style="overflow-x:auto;"><table style="width:100%;border-collapse:separate;border-spacing:0 6px;font-size:0.82rem;">';
                h += '<thead><tr style="color:#64748b;text-transform:uppercase;letter-spacing:1px;font-size:0.65rem;">';
                h += '<th style="padding:6px 10px;">#</th><th style="padding:6px 10px;">Otel / Şehir</th><th style="padding:6px 10px;">Oda</th><th style="padding:6px 10px;">Giriş</th><th style="padding:6px 10px;">Çıkış</th><th style="padding:6px 10px;">Tutar</th><th style="padding:6px 10px;">Durum</th><th style="padding:6px 10px;">İşlem</th>';
                h += '</tr></thead><tbody>';
                data.forEach(r => {
                    const aktif = r.durum === 'Aktif' || r.durum === 'OdaKapatildi';
                    const aciga = r.durum === 'Aktif';
                    let btn = '';
                    if (aktif) btn += `<button onclick="rezIptal(${r.id})" style="background:#ef444420;border:1px solid #ef4444;color:#ef4444;padding:3px 9px;border-radius:8px;font-size:0.65rem;font-weight:700;cursor:pointer;margin-right:4px;"><i class="bi bi-x-circle me-1"></i>İptal</button>`;
                    if (aciga) btn += `<button onclick="rezAcigaAl(${r.id})" style="background:#6366f120;border:1px solid #6366f1;color:#a5b4fc;padding:3px 9px;border-radius:8px;font-size:0.65rem;font-weight:700;cursor:pointer;"><i class="bi bi-pause-circle me-1"></i>Açığa Al</button>`;
                    if (!btn) btn = '<span style="color:#475569;font-size:0.7rem;">—</span>';
                    const tutarHtml = r.indirimli
                        ? `<span style="color:#ef4444;text-decoration:line-through;font-size:0.72rem;display:block;">${r.orijinalTutar} TL</span><span style="color:#10b981;font-weight:800;">${r.tutar} TL</span> <span style="background:#10b98122;color:#10b981;font-size:0.6rem;padding:1px 6px;border-radius:10px;font-weight:700;">%15 İND.</span>`
                        : `<span style="color:#d4af37;font-weight:700;">${r.tutar} TL</span>`;
                    h += `<tr style="background:rgba(255,255,255,0.04);">
                        <td style="padding:10px;color:#475569;font-weight:700;">#${r.id}</td>
                        <td style="padding:10px;font-weight:600;color:#fff;">${r.otelAd}<br><small style="color:#64748b;">${r.sehirAd}</small></td>
                        <td style="padding:10px;color:#d4af37;font-weight:800;">${r.odaNo}</td>
                        <td style="padding:10px;color:#cbd5e1;">${r.giris}</td>
                        <td style="padding:10px;color:#cbd5e1;">${r.cikis}</td>
                        <td style="padding:10px;">${tutarHtml}</td>
                        <td style="padding:10px;">${durumBadge(r.durum)}</td>
                        <td style="padding:10px;">${btn}</td>
                    </tr>`;
                });
                h += '</tbody></table></div>';
                $('#myRezBody').html(h);
            }).fail(function() {
                $('#myRezBody').html('<p class="text-danger text-center py-3">Rezervasyonlar yüklenemedi.</p>');
            });
        }

        function rezIptal(id) {
            Swal.fire({ title: 'Rezervasyonu İptal Et', text: '%15 iptal kesintisi uygulanacaktır. Onaylıyor musunuz?', icon: 'warning', showCancelButton: true, confirmButtonText: 'Evet, İptal Et', cancelButtonText: 'Vazgeç', confirmButtonColor: '#ef4444', background: '#0f172a', color: '#fff'
            }).then(r => {
                if (!r.isConfirmed) return;
                $.post('/Rezervasyon/CancelReservation', { id: id }, function(res) {
                    if (res.success) {
                        Swal.fire({ title: 'İptal Edildi', text: res.message, icon: 'success', background: '#0f172a', color: '#fff', confirmButtonColor: '#d4af37', timer: 2500, showConfirmButton: false });
                        loadMyRez();
                    } else { Swal.fire('Hata', res.message || 'Bir hata oluştu.', 'error'); }
                });
            });
        }

        function rezAcigaAl(id) {
            Swal.fire({ title: 'Açığa Al', text: 'Rezervasyon açığa alınacak. Kredi olarak kullanabilirsiniz.', icon: 'info', showCancelButton: true, confirmButtonText: 'Evet, Açığa Al', cancelButtonText: 'Vazgeç', confirmButtonColor: '#6366f1', background: '#0f172a', color: '#fff'
            }).then(r => {
                if (!r.isConfirmed) return;
                $.post('/Rezervasyon/HoldReservation', { id: id }, function(res) {
                    if (res.success) {
                        Swal.fire({ title: 'Açığa Alındı', text: res.message, icon: 'success', background: '#0f172a', color: '#fff', confirmButtonColor: '#d4af37', timer: 2000, showConfirmButton: false });
                        loadMyRez();
                    } else { Swal.fire('Hata', res.message || 'Bir hata oluştu.', 'error'); }
                });
            });
        }

        function loadMyReservations() { if (typeof loadMyRez === 'function') loadMyRez(); }

        $(document).ready(function() {
            checkUserStatus();
            const savedLang = localStorage.getItem("selectedLang") || 'tr';
            $("#globalLangSelector").val(savedLang);
            globalChangeLang(savedLang);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
