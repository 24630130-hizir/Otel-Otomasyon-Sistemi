@model projeotel.Models.Rezervasyon
<div class="container mt-4">
    <h2>Rezervasyon Yap</h2>

    @if (ViewBag.Mesaj != null)
    {
        <div class="alert alert-warning border-2 shadow-sm">
            <strong>Sistemden Mesaj:</strong> @ViewBag.Mesaj
        </div>
    }

    <form asp-controller="Rezervasyon" asp-action="Index" method="post" class="mt-3">
        <div class="mb-2">
            <label>Müşteri Bilgileri</label><br />
            <input asp-for="Ad" placeholder="Ad" class="form-control mb-2" required />
            <input asp-for="Soyad" placeholder="Soyad" class="form-control mb-2" required />
            <input asp-for="TcNo" placeholder="TC Kimlik No" class="form-control mb-2" maxlength="11" required />
            <input asp-for="Telefon" placeholder="Telefon" class="form-control mb-2" />
            <input asp-for="Email" placeholder="Email" class="form-control mb-2" />
        </div>

        <hr />

        <div class="mb-2">
            <label>Konaklama Bilgileri</label><br />
            <input asp-for="BungalovId" placeholder="Bungalov No (Örn: 1)" class="form-control mb-2" required />

            <label>Giriş Tarihi</label>
            <input asp-for="GirisTarihi" type="date" class="form-control mb-2" required />

            <label>Çıkış Tarihi</label>
            <input asp-for="CikisTarihi" type="date" class="form-control mb-2" required />
        </div>

        <button type="submit" class="btn btn-success btn-lg mt-3">Rezervasyonu Tamamla</button>
    </form>
</div>