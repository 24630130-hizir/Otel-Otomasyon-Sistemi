@model IEnumerable<dynamic>

<div class="container mt-4">
    <h2 class="text-white mb-4"><i class="bi bi-door-open-fill me-2"></i>Oda Durum Yönetimi</h2>

    <div class="row g-4">
        @foreach (var oda in Model)
        {
            <div class="col-md-3">
                <div class="card @(oda.Durum == "Müsait" ? "bg-success" : "bg-danger") text-white shadow-lg border-0 rounded-4">
                    <div class="card-body text-center">
                        <h1 class="display-6 fw-bold">@oda.OdaNo</h1>
                        <p class="mb-2">@oda.Tip</p>
                        <hr class="border-light">
                        <p class="fw-bold">@oda.Durum</p>

                        <form asp-action="OdaDurumGuncelle" method="post">
                            <input type="hidden" name="id" value="@oda.Id" />
                            <select name="yeniDurum" class="form-select form-select-sm mb-2" onchange="this.form.submit()">
                                <option selected disabled>Durum Değiştir</option>
                                <option value="Müsait">Müsait</option>
                                <option value="Dolu">Dolu</option>
                                <option value="Temizlikte">Temizlikte</option>
                                <option value="Tadilatta">Tadilatta</option>
                            </select>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>