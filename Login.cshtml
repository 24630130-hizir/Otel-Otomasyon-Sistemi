@{
    Layout = null;
    ViewData["Title"] = "Admin Giriş";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Giriş - Kingo</title>
    <link rel="icon" type="image/png" href="https://cdn-icons-png.flaticon.com/512/2696/2696144.png">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root { --gold: #d4af37; }
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            font-family: 'Plus Jakarta Sans', sans-serif; overflow: hidden; position: relative;
        }

        /* Hareketli otel arka planı */
        .bg-scene {
            position: fixed; inset: 0; z-index: 0;
            background: #030712;
        }

        /* Yüzen otel binaları */
        .hotel-skyline {
            position: absolute; bottom: 0; left: 0; right: 0; height: 100%;
            overflow: hidden;
        }

        /* Animasyonlu arka plan gradyanı */
        .bg-gradient-anim {
            position: absolute; inset: 0;
            background: linear-gradient(135deg, #030712 0%, #0a1628 40%, #030712 100%);
            animation: bgPulse 8s ease-in-out infinite alternate;
        }
        @@keyframes bgPulse {
            0% { background: linear-gradient(135deg, #030712 0%, #0a1628 40%, #030712 100%); }
            100% { background: linear-gradient(135deg, #030712 0%, #0d1f3c 40%, #030712 100%); }
        }

        /* Yıldızlar */
        .stars { position: absolute; inset: 0; }
        .star {
            position: absolute; background: #fff; border-radius: 50%;
            animation: twinkle var(--dur, 3s) ease-in-out infinite alternate;
        }
        @@keyframes twinkle { 0% { opacity: 0.1; } 100% { opacity: 0.9; } }

        /* Otel binaları SVG benzeri CSS */
        .building {
            position: absolute; bottom: 0;
            background: linear-gradient(to top, #0d1f3c, #0a1628);
            border-top: 2px solid rgba(212,175,55,0.3);
        }
        .building::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0;
            background: repeating-linear-gradient(
                to bottom,
                transparent 0px, transparent 18px,
                rgba(212,175,55,0.08) 18px, rgba(212,175,55,0.08) 20px
            );
            height: 100%;
        }
        /* Pencereler */
        .building .windows {
            position: absolute; inset: 10px 8px; display: grid;
            grid-template-columns: repeat(var(--cols, 3), 1fr);
            gap: 6px; padding: 8px;
        }
        .win {
            background: rgba(212,175,55,0.15); border-radius: 2px;
            animation: winBlink var(--bd, 4s) ease-in-out infinite alternate;
        }
        .win.lit { background: rgba(212,175,55,0.6); }
        @@keyframes winBlink { 0% { opacity: 0.3; } 100% { opacity: 1; } }

        /* Ay */
        .moon {
            position: absolute; top: 8%; right: 12%;
            width: 70px; height: 70px;
            background: radial-gradient(circle at 35% 35%, #f1d37e, #d4af37);
            border-radius: 50%;
            box-shadow: 0 0 40px rgba(212,175,55,0.4), 0 0 80px rgba(212,175,55,0.15);
            animation: moonFloat 6s ease-in-out infinite alternate;
        }
        @@keyframes moonFloat { 0% { transform: translateY(0); } 100% { transform: translateY(-15px); } }

        /* Uçan kuşlar */
        .bird {
            position: absolute; font-size: 1.2rem; opacity: 0.4;
            animation: birdFly var(--bd, 20s) linear infinite;
        }
        @@keyframes birdFly {
            0% { transform: translateX(-100px); opacity: 0; }
            10% { opacity: 0.4; }
            90% { opacity: 0.4; }
            100% { transform: translateX(110vw); opacity: 0; }
        }

        /* Işık huzmesi */
        .light-beam {
            position: absolute; bottom: 0; width: 3px;
            background: linear-gradient(to top, rgba(212,175,55,0.4), transparent);
            animation: beamPulse 4s ease-in-out infinite alternate;
        }
        @@keyframes beamPulse { 0% { opacity: 0.3; height: 40%; } 100% { opacity: 0.8; height: 60%; } }

        /* Giriş kartı */
        .login-wrapper {
            position: relative; z-index: 10;
            width: 100%; max-width: 420px; padding: 20px;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(212,175,55,0.3);
            border-radius: 24px;
            padding: 44px 40px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
        }

        .login-logo {
            text-align: center; margin-bottom: 32px;
        }
        .login-logo .icon-wrap {
            width: 64px; height: 64px; margin: 0 auto 12px;
            background: linear-gradient(135deg, rgba(212,175,55,0.2), rgba(212,175,55,0.05));
            border: 1px solid rgba(212,175,55,0.5); border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem; color: var(--gold);
        }
        .login-logo h4 {
            font-family: 'Playfair Display', serif; color: var(--gold);
            font-size: 1.4rem; letter-spacing: 2px; margin: 0;
        }
        .login-logo p { color: rgba(255,255,255,0.4); font-size: 0.72rem; letter-spacing: 3px; text-transform: uppercase; margin: 4px 0 0; }

        .field-group { margin-bottom: 18px; }
        .field-group label { display: block; font-size: 0.7rem; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
        .field-wrap { position: relative; }
        .field-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--gold); font-size: 0.9rem; }
        .field-wrap input {
            width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px; padding: 13px 14px 13px 42px; color: #fff; outline: none;
            font-size: 0.9rem; transition: 0.3s; font-family: inherit;
        }
        .field-wrap input:focus { border-color: var(--gold); background: rgba(255,255,255,0.09); }
        .field-wrap input::placeholder { color: rgba(255,255,255,0.25); }

        .btn-login {
            width: 100%; background: linear-gradient(135deg, var(--gold), #aa8928);
            color: #000; border: none; border-radius: 12px; padding: 14px;
            font-weight: 800; font-size: 0.85rem; letter-spacing: 1.5px; text-transform: uppercase;
            cursor: pointer; transition: 0.3s; margin-top: 8px;
        }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(212,175,55,0.35); }
        .btn-login:active { transform: translateY(0); }

        .back-link {
            display: block; text-align: center; margin-top: 20px;
            color: rgba(255,255,255,0.35); font-size: 0.75rem; text-decoration: none; transition: 0.2s;
        }
        .back-link:hover { color: var(--gold); }

        .error-msg { color: #ef4444; font-size: 0.78rem; margin-top: 6px; display: none; }
    </style>
</head>
<body>
    <!-- ARKA PLAN -->
    <div class="bg-scene">
        <div class="bg-gradient-anim"></div>
        <div class="stars" id="starsContainer"></div>
        <div class="moon"></div>

        <!-- Kuşlar -->
        <div class="bird" style="top:20%;--bd:22s;">🕊</div>
        <div class="bird" style="top:30%;--bd:28s;animation-delay:5s;">🕊</div>
        <div class="bird" style="top:15%;--bd:35s;animation-delay:12s;font-size:0.9rem;">🕊</div>

        <!-- Binalar -->
        <div class="hotel-skyline" id="skyline"></div>

        <!-- Işık huzmeleri -->
        <div class="light-beam" style="left:20%;height:45%;animation-delay:0s;"></div>
        <div class="light-beam" style="left:50%;height:55%;animation-delay:2s;"></div>
        <div class="light-beam" style="left:80%;height:40%;animation-delay:1s;"></div>
    </div>

    <!-- GİRİŞ KARTI -->
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-logo">
                <div class="icon-wrap"><i class="bi bi-shield-lock-fill"></i></div>
                <h4>KINGO</h4>
                <p>Yönetim Paneli</p>
            </div>

            <div class="field-group">
                <label>Kullanıcı Adı</label>
                <div class="field-wrap">
                    <i class="bi bi-person-fill"></i>
                    <input type="text" id="kullaniciAd" placeholder="Kullanıcı adınız..." autocomplete="username" />
                </div>
            </div>

            <div class="field-group">
                <label>Şifre</label>
                <div class="field-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input type="password" id="sifre" placeholder="Şifreniz..." autocomplete="current-password" />
                </div>
            </div>

            <div class="error-msg" id="errorMsg"><i class="bi bi-exclamation-circle me-1"></i><span id="errorText"></span></div>

            <button class="btn-login" id="loginBtn" onclick="doLogin()">
                <i class="bi bi-box-arrow-in-right me-2"></i>GİRİŞ YAP
            </button>

            <a href="/" class="back-link"><i class="bi bi-arrow-left me-1"></i>Ana sayfaya dön</a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        // Yıldızlar
        const starsContainer = document.getElementById('starsContainer');
        for (let i = 0; i < 120; i++) {
            const star = document.createElement('div');
            star.className = 'star';
            const size = Math.random() * 2.5 + 0.5;
            star.style.cssText = `width:${size}px;height:${size}px;top:${Math.random()*70}%;left:${Math.random()*100}%;--dur:${2+Math.random()*4}s;animation-delay:${Math.random()*4}s;`;
            starsContainer.appendChild(star);
        }

        // Binalar
        const skyline = document.getElementById('skyline');
        const buildings = [
            { left: '2%',  width: 80,  height: 220, cols: 3 },
            { left: '8%',  width: 120, height: 320, cols: 4 },
            { left: '16%', width: 70,  height: 180, cols: 2 },
            { left: '22%', width: 100, height: 280, cols: 3 },
            { left: '30%', width: 140, height: 380, cols: 5 },
            { left: '40%', width: 90,  height: 250, cols: 3 },
            { left: '48%', width: 60,  height: 160, cols: 2 },
            { left: '54%', width: 110, height: 300, cols: 4 },
            { left: '63%', width: 130, height: 350, cols: 4 },
            { left: '73%', width: 80,  height: 200, cols: 3 },
            { left: '80%', width: 100, height: 270, cols: 3 },
            { left: '88%', width: 70,  height: 190, cols: 2 },
            { left: '93%', width: 90,  height: 240, cols: 3 },
        ];

        buildings.forEach(b => {
            const div = document.createElement('div');
            div.className = 'building';
            div.style.cssText = `left:${b.left};width:${b.width}px;height:${b.height}px;`;

            const wins = document.createElement('div');
            wins.className = 'windows';
            wins.style.setProperty('--cols', b.cols);
            const rows = Math.floor(b.height / 28);
            for (let i = 0; i < rows * b.cols; i++) {
                const w = document.createElement('div');
                w.className = 'win' + (Math.random() > 0.4 ? ' lit' : '');
                w.style.setProperty('--bd', (2 + Math.random() * 5) + 's');
                w.style.animationDelay = (Math.random() * 3) + 's';
                wins.appendChild(w);
            }
            div.appendChild(wins);
            skyline.appendChild(div);
        });

        // Login
        function doLogin() {
            const ad = $('#kullaniciAd').val().trim();
            const sifre = $('#sifre').val().trim();
            if (!ad || !sifre) { showError('Lütfen tüm alanları doldurun.'); return; }

            $('#loginBtn').prop('disabled', true).html('<i class="bi bi-hourglass-split me-2"></i>Doğrulanıyor...');
            $('#errorMsg').hide();

            $.ajax({
                url: '/Admin/Login',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded',
                data: { kullaniciAd: ad, sifre: sifre },
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() || '' },
                success: function(res) {
                    if (res && res.success) {
                        $('#loginBtn').html('<i class="bi bi-check-circle me-2"></i>Giriş Başarılı!');
                        setTimeout(() => { window.location.href = '/Admin'; }, 600);
                    } else {
                        showError((res && res.message) ? res.message : 'Giriş başarısız.');
                        $('#loginBtn').prop('disabled', false).html('<i class="bi bi-box-arrow-in-right me-2"></i>GİRİŞ YAP');
                    }
                },
                error: function(xhr) {
                    const msg = (xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : 'Sunucu hatası (' + xhr.status + '). Lütfen tekrar deneyin.';
                    showError(msg);
                    $('#loginBtn').prop('disabled', false).html('<i class="bi bi-box-arrow-in-right me-2"></i>GİRİŞ YAP');
                }
            });
        }

        function showError(msg) {
            $('#errorText').text(msg);
            $('#errorMsg').show();
        }

        $('#sifre').on('keypress', function(e) { if (e.which === 13) doLogin(); });
        $('#kullaniciAd').on('keypress', function(e) { if (e.which === 13) $('#sifre').focus(); });
    </script>
</body>
</html>
