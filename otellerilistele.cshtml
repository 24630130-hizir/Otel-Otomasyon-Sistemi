@model dynamic
@{
    ViewData["Title"] = "Otel Listesi";
}

<div class="container mt-5">
    <h2 class="text-center mb-4">Otelleri Keşfet</h2>

    @if (Model == null)
    {
        <div class="alert alert-danger">
            <h4 class="alert-heading">Veri Alınamadı!</h4>
            <p>API şu an cevap vermiyor veya gönderdiğimiz sorguda (RegionId) bir hata var.</p>
            <hr>
            <p class="mb-0">Lütfen RapidAPI panelinden anahtarınızın aktif olduğunu kontrol edin.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var otel in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        @*  *@
                        <img src="@(otel?.propertyImage?.image?.url ?? "https://via.placeholder.com/400x250?text=Resim+Bulunamadi")"
                             class="card-img-top" alt="Otel">

                        <div class="card-body">
                            <h5 class="card-title fw-bold">@otel?.name</h5>
                            <p class="text-muted small">Konum: @(otel?.neighborhood?.name ?? "Merkez")</p>

                            <div class="d-flex justify-content-between align-items-center">
                                @*  *@
                                <span class="h5 text-primary mb-0">@(otel?.price?.lead?.formatted ?? "Fiyat Bilgisi Yok")</span>
                                <span class="badge bg-info text-dark">⭐ @(otel?.reviews?.score ?? "N/A")</span>
                            </div>

                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary w-100 mt-3 rounded-pill">
                                Rezervasyon Yap
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>